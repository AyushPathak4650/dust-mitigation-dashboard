# AeroDust-Shield Production Environment Variables Config Example
# Copy this file to '.env' and fill in credentials.

# App Config
VITE_APP_ENV=development
VITE_APP_PORT=3000

# Central CECB API Integration Config (Secure by default, no default API keys)
VITE_CECB_API_URL=https://api.cecb.cg.gov.in/v1/dust-mitigation
VITE_CECB_API_KEY=your_secure_api_key_here

# Analytics Rate Limiting & Performance Parameters
VITE_ANALYTICS_UPDATE_INTERVAL_MS=5000
VITE_ENABLE_MOCK_DEMO_DATA=true
